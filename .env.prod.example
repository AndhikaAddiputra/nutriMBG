# NutriMBG — Production Environment (Neon + Tunnel)
# Copy to .env then run backend locally.

# === DATABASE (Neon PostgreSQL) ===
# 1. Daftar https://neon.tech (Google/GitHub, gratis tanpa kartu)
# 2. Create project → kopi "Connection string" (PSL mode)
# 3. Tempel di bawah
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb

# === JWT ===
JWT_SECRET=change-me-to-random-64-chars
JWT_EXP_HOURS=8

# === GEMINI AI ===
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# === CORS ===
# Isi dengan URL Vercel nanti + localhost
# Format: JSON array atau comma-separated
CORS_ORIGINS=["https://nutrimbg.vercel.app","http://localhost:5173"]

# === OPSIONAL ===
ENVIRONMENT=production
RATE_LIMIT_BACKEND=db
